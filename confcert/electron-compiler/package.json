{
  "name": "solidity-playground-electron",
  "version": "1.1.4",
  "description": "Offline Solidity Playground — Electron Desktop App",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node sync-version.js && electron .",
    "dev": "node sync-version.js && electron . --dev",
    "setup": "npm install",
    "prebuild": "node sync-version.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:win:publish": "electron-builder --win --publish=never",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.45.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.solidityplayground.app",
    "productName": "Solidity Playground",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "omegaopinmthechat",
      "repo": "blockchain_projects",
      "releaseType": "release",
      "publishAutoUpdate": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "version.js"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/final_icon.ico"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "assets/final_icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Solidity Playground",
      "installerIcon": "assets/final_icon.ico",
      "uninstallerIcon": "assets/final_icon.ico",
      "artifactName": "${productName}-Installer-${version}.${ext}"
    },
    "linux": {
      "icon": "assets/final_icon.ico",
      "target": "AppImage"
    }
  }
}
